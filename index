<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>여기시러 - 가짜 여행 예약 플랫폼</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;700;900&display=swap');
        body { font-family: 'Noto Sans KR', sans-serif; background-color: #f8fafc; }
        .yeogi-orange { background-color: #ff5a22; }
        .yeogi-text-orange { color: #ff5a22; }
        .yeogi-border-orange { border-color: #ff5a22; }
        .hidden { display: none; }
        .drag-over { background-color: #ffedd5 !important; border: 2px dashed #ff5a22 !important; }
        /* 가로 스크롤바 숨기기 스타일 */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="pb-24">

<header class="yeogi-orange text-white p-4 sticky top-0 z-50 shadow-md">
    <div class="max-w-4xl mx-auto flex flex-col gap-3">
        <div class="flex justify-between items-center">
            <div onclick="showSection('home-section')" class="text-2xl font-black cursor-pointer tracking-tighter">여기시러 ✈️</div>
            <div class="flex gap-4 items-center">
                <button onclick="showSection('storage-section')" class="relative text-sm font-bold bg-white/20 px-3 py-1.5 rounded-full hover:bg-white/30 transition">
                    🧳 보관함 <span id="storage-count" class="absolute -top-1 -right-2 bg-yellow-400 text-black text-[10px] font-black rounded-full px-1.5">0</span>
                </button>
            </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
            <div class="relative">
                <input type="text" id="search-keyword" placeholder="어디로 떠나고 싶으신가요? (관광지/숙소/식당)" class="w-full p-3 rounded-lg text-black focus:outline-none text-sm shadow-inner pl-9">
                <span class="absolute left-3 top-3.5 text-xs">🔍</span>
            </div>
            <div class="relative flex gap-1">
                <select id="search-region-select" class="p-3 rounded-lg text-black focus:outline-none text-sm shadow-inner bg-white font-bold w-1/3">
                    <option value="all">전체 지역</option>
                </select>
                <button onclick="executeTotalSearch()" class="w-2/3 bg-gray-900 text-white font-bold rounded-lg text-sm hover:bg-gray-800 transition">검색하기</button>
            </div>
        </div>
    </div>
</header>

<main class="max-w-4xl mx-auto p-4">

    <section id="home-section" class="block">
        <div class="grid grid-cols-4 gap-3 text-center my-6">
            <div onclick="loadCategoryPage('관광지')" class="bg-white p-4 rounded-xl shadow-sm cursor-pointer hover:scale-105 transition border hover:border-[#ff5a22]">
                <div class="text-3xl mb-1">🗺️</div><div class="text-xs font-bold text-gray-700">관광지</div>
            </div>
            <div onclick="loadCategoryPage('숙소')" class="bg-white p-4 rounded-xl shadow-sm cursor-pointer hover:scale-105 transition border hover:border-[#ff5a22]">
                <div class="text-3xl mb-1">🏨</div><div class="text-xs font-bold text-gray-700">숙소</div>
            </div>
            <div onclick="loadCategoryPage('맛집')" class="bg-white p-4 rounded-xl shadow-sm cursor-pointer hover:scale-105 transition border hover:border-[#ff5a22]">
                <div class="text-3xl mb-1">🍲</div><div class="text-xs font-bold text-gray-700">맛집</div>
            </div>
            <div onclick="loadCategoryPage('항공권')" class="bg-white p-4 rounded-xl shadow-sm cursor-pointer hover:scale-105 transition border hover:border-[#ff5a22]">
                <div class="text-3xl mb-1">✈️</div><div class="text-xs font-bold text-gray-700">항공권</div>
            </div>
        </div>

        <div class="mt-8">
            <h2 class="text-xl font-black text-gray-800 mb-4 flex items-center gap-2">🔥 이번 주 추천 여행지</h2>
            <div id="recommend-container" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                </div>
        </div>
    </section>

    <section id="search-result-section" class="hidden">
        <div class="flex justify-between items-end mb-4 border-b pb-2">
            <h2 class="text-xl font-black text-gray-800">통합 검색 결과</h2>
            <button onclick="showSection('home-section')" class="text-gray-400 text-sm">닫기</button>
        </div>
        <div id="search-results-container" class="grid gap-4"></div>
    </section>

    <section id="category-list-section" class="hidden">
        <div class="flex justify-between items-center mb-4">
            <h2 id="current-category-title" class="text-xl font-black text-gray-800">카테고리</h2>
            <button onclick="showAddItemModal()" class="yeogi-orange text-white px-3 py-1.5 rounded-lg text-xs font-bold shadow-sm">+ 정보 추가</button>
        </div>

        <div class="bg-white p-4 shadow-sm rounded-xl mb-4 border flex flex-col gap-2">
            <div class="flex justify-between items-center flex-wrap gap-2">
                <span class="text-xs text-gray-400 font-bold">📍 탐색할 대도시/지역을 선택하거나 관리하세요.</span>
                <div class="flex gap-1">
                    <button onclick="addNewRegionDirect()" class="bg-emerald-500 text-white px-2 py-1 rounded text-[11px] font-bold shadow-sm hover:bg-emerald-600">➕ 지역추가</button>
                    <button onclick="showEditRegionModal()" class="bg-blue-500 text-white px-2 py-1 rounded text-[11px] font-bold shadow-sm hover:bg-blue-600">✏️ 지역수정</button>
                    <button onclick="showDeleteRegionModal()" class="bg-red-500 text-white px-2 py-1 rounded text-[11px] font-bold shadow-sm hover:bg-red-600">❌ 지역삭제</button>
                </div>
            </div>
            <div id="region-scroll-box" class="flex gap-2 overflow-x-auto p-1 no-scrollbar border-t pt-2"></div>
        </div>

        <div class="bg-white p-4 shadow-sm rounded-xl mb-4 border flex flex-col gap-2">
            <div class="flex justify-between items-center flex-wrap gap-2">
                <span class="text-xs text-gray-400 font-bold">📁 세부 서브 카테고리를 분류 필터링하세요.</span>
                <div class="flex gap-1">
                    <button onclick="addNewSubCategoryDirect()" class="bg-amber-500 text-white px-2 py-1 rounded text-[11px] font-bold shadow-sm hover:bg-amber-600">➕ 분류추가</button>
                    <button onclick="showEditSubCategoryModal()" class="bg-indigo-500 text-white px-2 py-1 rounded text-[11px] font-bold shadow-sm hover:bg-indigo-600">✏️ 분류수정</button>
                    <button onclick="showDeleteSubCategoryModal()" class="bg-rose-500 text-white px-2 py-1 rounded text-[11px] font-bold shadow-sm hover:bg-rose-600">❌ 분류삭제</button>
                </div>
            </div>
            <div id="subcategory-scroll-box" class="flex gap-2 overflow-x-auto p-1 no-scrollbar border-t pt-2"></div>
        </div>

        <div id="items-container" class="grid gap-4 mt-4"></div>
    </section>

    <section id="item-detail-section" class="hidden">
        <div id="item-info-view" class="bg-white p-6 rounded-xl shadow-sm border mb-4"></div>
        
        <div id="flight-simulator-box" class="bg-white p-6 rounded-xl shadow-sm border mb-4 hidden">
            <h3 class="font-black text-gray-800 text-base mb-3 border-b pb-2">✈️ 실시간 가짜 항공권 편명 스케줄</h3>
            <div class="grid gap-3" id="flight-ticket-list"></div>
        </div>

        <div id="normal-booking-box" class="bg-white p-5 rounded-xl border shadow-sm flex flex-col gap-3">
            <div class="flex justify-between items-center">
                <div>
                    <span class="text-xs text-gray-400 font-bold">체크인/이용 희망일 선택</span>
                    <input type="date" class="block border rounded p-2 text-xs mt-1 font-bold focus:outline-none" value="2026-06-06">
                </div>
                <div class="text-right">
                    <p class="text-xs text-gray-400 font-bold">1인/1박 기준 요금</p>
                    <p id="detail-price-text" class="text-xl font-black yeogi-text-orange">0원</p>
                </div>
            </div>
            <div class="flex gap-2">
                <button onclick="addItemToStorage()" class="flex-1 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-bold rounded-lg transition">🧳 보관함에 저장</button>
                <button onclick="triggerFakeBookingSimulation()" class="flex-1 py-3 yeogi-orange hover:bg-orange-600 text-white text-sm font-bold rounded-lg shadow-md transition">⚡ 실시간 즉시 예약하기</button>
            </div>
        </div>
    </section>

    <section id="storage-section" class="hidden">
        <h2 class="text-xl font-black mb-4">내 보관함 플래너</h2>
        <div id="storage-items-list" class="bg-white p-4 rounded-xl shadow-sm border mb-4"></div>
        <div class="bg-white p-4 rounded-xl border mb-4 flex justify-between items-center">
            <span class="text-sm font-bold text-gray-500">가상 총 예상 비용</span>
            <span id="storage-total-price" class="text-xl font-black yeogi-text-orange">0원</span>
        </div>
        <button onclick="triggerFakeBookingSimulation()" class="w-full py-4 yeogi-orange text-white text-base font-black rounded-xl shadow-lg hover:bg-orange-600 transition">📝 가상 여행 일정 전체 일괄 예약</button>
    </section>

    <section id="booking-status-section" class="hidden text-center p-10 bg-white rounded-xl border shadow-sm">
        <div class="text-6xl mb-4 animate-bounce">🚀</div>
        <h2 id="status-headline" class="text-2xl font-black mb-2 text-gray-800">예약 신호 전송 중...</h2>
        <p class="text-xs text-red-500 font-bold mb-6">⚠️ 전세계 호스트 네트워크 인프라에 접근을 시도 중입니다.</p>
        <div class="w-full bg-gray-100 h-3 rounded-full overflow-hidden mb-8 max-w-md mx-auto border">
            <div id="booking-progress-bar" class="yeogi-orange h-full transition-all duration-700" style="width: 0%"></div>
        </div>
        <div id="simulation-fail-notice" class="hidden max-w-md mx-auto p-4 bg-red-50 text-red-700 rounded-lg text-xs font-bold leading-relaxed mb-6 border border-red-100">
            ❌ [예약 시스템 작동 불능 예외 안내]<br>
            본 플랫폼은 데이터 영속성 관리 프로토콜이 적용된 프론트엔드 모조 목업(Mock-up) 소프트웨어입니다. 암호화 서명 프로토콜 부재 및 실결제 API 통신 미동기 상태이므로 실제 여정이 확약되지 않습니다.
        </div>
        <button onclick="showSection('home-section')" class="w-full max-w-md py-3 bg-gray-900 text-white rounded-lg font-bold hover:bg-gray-800 transition">🏠 처음 메인 화면으로 이동</button>
    </section>
</main>

<nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 shadow-xl z-40">
    <div class="max-w-4xl mx-auto grid grid-cols-5 text-center text-[10px] font-bold text-gray-500">
        <button onclick="showSection('home-section')" class="py-2.5 flex flex-col items-center gap-0.5 hover:text-[#ff5a22]">
            <span class="text-xl">🏠</span>홈
        </button>
        <button onclick="loadCategoryPage('관광지')" class="py-2.5 flex flex-col items-center gap-0.5 hover:text-[#ff5a22]">
            <span class="text-xl">🗺️</span>관광지
        </button>
        <button onclick="loadCategoryPage('숙소')" class="py-2.5 flex flex-col items-center gap-0.5 hover:text-[#ff5a22]">
            <span class="text-xl">🏨</span>숙소
        </button>
        <button onclick="loadCategoryPage('맛집')" class="py-2.5 flex flex-col items-center gap-0.5 hover:text-[#ff5a22]">
            <span class="text-xl">🍲</span>맛집
        </button>
        <button onclick="showSection('storage-section')" class="py-2.5 flex flex-col items-center gap-0.5 hover:text-[#ff5a22] border-l bg-orange-50/50">
            <span class="text-xl">🧳</span>보관함
        </button>
    </div>
</nav>

<div id="global-modal" class="fixed inset-0 bg-black bg-opacity-60 hidden flex items-center justify-center p-4 z-[100] animate-fade-in">
    <div class="bg-white w-full max-w-md p-6 rounded-2xl shadow-2xl">
        <h3 id="modal-headline" class="text-lg font-black mb-4 text-gray-900">입력 창</h3>
        <div id="modal-body-content" class="flex flex-col gap-3 max-h-[55vh] overflow-y-auto pr-1"></div>
        <div class="flex gap-2 mt-6">
            <button onclick="closeGlobalModal()" class="flex-1 py-2.5 bg-gray-100 text-gray-700 rounded-xl font-bold hover:bg-gray-200 transition">취소</button>
            <button id="modal-action-confirm-btn" class="flex-1 py-2.5 yeogi-orange text-white rounded-xl font-bold hover:bg-orange-600 transition">확인 완료</button>
        </div>
    </div>
</div>

<script>
    // 기본 모크 업 초기 데이터베이스 스케마 정의
    let db = JSON.parse(localStorage.getItem('yeogi_siro_db_v1')) || {
        regions: ["제주도", "부산", "서울", "강릉", "도쿄", "파리"],
        subCategories: {
            "관광지": ["자연/명소", "박물관/역사", "액티비티", "테마파크"],
            "숙소": ["5성급 호텔", "감성 펜션", "게스트하우스", "리조트"],
            "맛집": ["로컬 노포", "파인 다이닝", "카페/베이커리", "일식/스시"],
            "항공권": ["대한항공", "아시아나", "저비용항공(LCC)", "외항사"]
        },
        travelItems: [
            { id: 101, mainCat: "관광지", region: "제주도", subCat: "자연/명소", name: "성산일출봉 광치기해변", price: 0, score: "4.9", description: "성산일출봉을 배경으로 멋진 인생 사진과 낙타 체험이 가능한 천연 암반 해변지대입니다.", img: "https://images.unsplash.com/photo-1571746242326-62a8ef7ebd43?w=500&auto=format&fit=crop" },
            { id: 102, mainCat: "숙소", region: "부산", subCat: "5성급 호텔", name: "시그니엘 부산 해운대", price: 340000, score: "5.0", description: "탁 트인 해운대 오션뷰와 최고의 미식 슬롯을 자랑하는 최고급 럭셔리 호캉스 목적지.", img: "https://images.unsplash.com/photo-1566073771259-6a8506099945?w=500&auto=format&fit=crop" },
            { id: 103, mainCat: "맛집", region: "서울", subCat: "파인 다이닝", name: "정식당 청담", price: 180000, score: "4.8", description: "독창적인 한식 크리에이티브 뉴 클래식 요리를 구현하는 파인다이닝 명소.", img: "https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=500&auto=format&fit=crop" }
        ],
        storage: []
    };

    let currentMainCategory = "관광지";
    let selectedRegionFilter = "all";
    let selectedSubCategoryFilter = "all";
    let currentActiveItemId = null;

    function initApp() {
        renderGlobalRegionSelect();
        renderRecommendList();
        updateStorageBadgeCount();
    }

    // 전역 지역 셀렉트 컴포넌트 동기화
    function renderGlobalRegionSelect() {
        const select = document.getElementById('search-region-select');
        select.innerHTML = '<option value="all">전체 지역</option>';
        db.regions.forEach(r => {
            const opt = document.createElement('option');
            opt.value = r; opt.innerText = r;
            select.appendChild(opt);
        });
    }

    function showSection(id) {
        document.querySelectorAll('main > section').forEach(s => s.classList.add('hidden'));
        document.getElementById(id).classList.remove('hidden');
        window.scrollTo(0,0);
        if(id === 'storage-section') renderStorageItems();
    }

    // 메인 홈용 추천 리스트 바인딩
    function renderRecommendList() {
        const box = document.getElementById('recommend-container');
        box.innerHTML = "";
        
        // 데이터가 비었을 때 예외 처리
        if(db.travelItems.length === 0) {
            box.innerHTML = "<p class='text-gray-400 text-xs col-span-2 text-center py-6'>현재 등록된 추천 코스가 없습니다.</p>";
            return;
        }

        db.travelItems.slice(0, 4).forEach(item => {
            const card = document.createElement('div');
            card.className = "bg-white rounded-xl shadow-sm overflow-hidden border cursor-pointer hover:scale-[1.01] transition";
            card.onclick = () => showItemDetailView(item.id);
            card.innerHTML = `
                <img src="${item.img || 'https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=500&auto=format&fit=crop'}" class="w-full h-40 object-cover bg-gray-100">
                <div class="p-4">
                    <span class="text-[10px] bg-orange-100 yeogi-text-orange font-bold px-2 py-0.5 rounded-full">${item.region} | ${item.mainCat}</span>
                    <h3 class="font-bold text-gray-800 text-sm mt-1.5">${item.name}</h3>
                    <p class="text-xs text-gray-400 mt-1 line-clamp-1">${item.description}</p>
                    <div class="flex justify-between items-center mt-3 pt-2 border-t text-xs">
                        <span class="font-bold text-yellow-500">⭐ ${item.score}</span>
                        <span class="font-black text-gray-700">${item.price > 0 ? item.price.toLocaleString()+'원' : '입장 무료'}</span>
                    </div>
                </div>
            `;
            box.appendChild(card);
        });
    }

    // 통합 상단 엔진 검색 로직
    function executeTotalSearch() {
        const keyword = document.getElementById('search-keyword').value.trim();
        const region = document.getElementById('search-region-select').value;

        showSection('search-result-section');
        const container = document.getElementById('search-results-container');
        container.innerHTML = "";

        let results = db.travelItems;
        if(region !== 'all') results = results.filter(r => r.region === region);
        if(keyword) results = results.filter(r => r.name.includes(keyword) || r.description.includes(keyword) || r.subCat.includes(keyword));

        if(results.length === 0) {
            container.innerHTML = "<div class='text-center py-12 text-gray-400 font-bold text-sm'>일치하는 가짜 여정 데이터가 매칭되지 않았습니다.</div>";
            return;
        }

        results.forEach(item => {
            const div = document.createElement('div');
            div.className = "bg-white p-4 rounded-xl flex gap-4 cursor-pointer border shadow-sm items-center";
            div.onclick = () => showItemDetailView(item.id);
            div.innerHTML = `
                <img src="${item.img || 'https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=500&auto=format&fit=crop'}" class="w-16 h-16 object-cover rounded-xl bg-gray-100">
                <div class="flex-1">
                    <span class="text-[9px] text-gray-400 font-bold block">[${item.region}] ${item.mainCat} > ${item.subCat}</span>
                    <h4 class="font-bold text-gray-800 text-sm mt-0.5">${item.name}</h4>
                    <p class="text-xs yeogi-text-orange font-black mt-1">${item.price > 0 ? item.price.toLocaleString()+'원' : '비용 없음'}</p>
                </div>
            `;
            container.appendChild(div);
        });
    }

    // 대카테고리 네비게이션 스위칭 엔트리
    function loadCategoryPage(catName) {
        currentMainCategory = catName;
        selectedRegionFilter = "all";
        selectedSubCategoryFilter = "all";
        
        showSection('category-list-section');
        document.getElementById('current-category-title').innerText = `✈️ ${catName} 추천 카테고리`;
        
        renderScrollRegionButtons();
        renderScrollSubCategoryButtons();
        renderFilteredItemsGrid();
    }

    // 분리형 상위 스크롤바(지역) 가로 스크롤 동적 빌더
    function renderScrollRegionButtons() {
        const box = document.getElementById('region-scroll-box');
        box.innerHTML = "";

        const allBtn = document.createElement('button');
        allBtn.className = `px-3 py-1.5 rounded-full text-xs font-bold whitespace-nowrap transition-all ${selectedRegionFilter === 'all' ? 'yeogi-orange text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`;
        allBtn.innerText = "🌐 전체지역 보기";
        allBtn.onclick = () => { selectedRegionFilter = "all"; renderScrollRegionButtons(); renderFilteredItemsGrid(); };
        box.appendChild(allBtn);

        db.regions.forEach(r => {
            const btn = document.createElement('button');
            btn.className = `px-3 py-1.5 rounded-full text-xs font-bold whitespace-nowrap transition-all ${selectedRegionFilter === r ? 'yeogi-orange text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`;
            btn.innerText = `📍 ${r}`;
            btn.onclick = () => { selectedRegionFilter = r; renderScrollRegionButtons(); renderFilteredItemsGrid(); };
            box.appendChild(btn);
        });
    }

    // 분리형 하위 스크롤바(서브 종류) 가로 스크롤 동적 빌더
    function renderScrollSubCategoryButtons() {
        const box = document.getElementById('subcategory-scroll-box');
        box.innerHTML = "";

        const allBtn = document.createElement('button');
        allBtn.className = `px-3 py-1.5 rounded-full text-xs font-bold whitespace-nowrap transition-all ${selectedSubCategoryFilter === 'all' ? 'bg-slate-800 text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`;
        allBtn.innerText = "📁 전체테마 보기";
        allBtn.onclick = () => { selectedSubCategoryFilter = "all"; renderScrollSubCategoryButtons(); renderFilteredItemsGrid(); };
        box.appendChild(allBtn);

        const subList = db.subCategories[currentMainCategory] || [];
        subList.forEach(sc => {
            const btn = document.createElement('button');
            btn.className = `px-3 py-1.5 rounded-full text-xs font-bold whitespace-nowrap transition-all ${selectedSubCategoryFilter === sc ? 'bg-slate-800 text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`;
            btn.innerText = `🏷️ ${sc}`;
            btn.onclick = () => { selectedSubCategoryFilter = sc; renderScrollSubCategoryButtons(); renderFilteredItemsGrid(); };
            box.appendChild(btn);
        });
    }

    // 메인 아이템 필터링 그리드 연산 제어
    function renderFilteredItemsGrid() {
        const container = document.getElementById('items-container');
        container.innerHTML = "";

        let list = db.travelItems.filter(item => item.mainCat === currentMainCategory);
        if(selectedRegionFilter !== 'all') list = list.filter(item => item.region === selectedRegionFilter);
        if(selectedSubCategoryFilter !== 'all') list = list.filter(item => item.subCat === selectedSubCategoryFilter);

        if(list.length === 0) {
            container.innerHTML = `
                <div class="bg-white p-12 text-center text-gray-400 text-xs rounded-xl border border-dashed col-span-full">
                    해당 통합 필터에 일치하는 등록 작품/여행지 정보가 존재하지 않습니다. 상단에서 신규로 구성해 보세요!
                </div>`;
            return;
        }

        list.forEach(res => {
            const card = document.createElement('div');
            card.className = "bg-white p-4 rounded-xl shadow-sm border flex gap-4 items-center justify-between";
            
            const infoDiv = document.createElement('div');
            infoDiv.className = "flex gap-4 flex-1 items-center cursor-pointer";
            infoDiv.onclick = () => showItemDetailView(res.id);

            const imgHtml = res.img 
                ? `<img src="${res.img}" class="w-16 h-16 object-cover rounded-xl shadow-inner bg-gray-50">`
                : `<div class="w-16 h-16 bg-gray-100 rounded-xl flex items-center justify-center text-xl">🖼️</div>`;

            infoDiv.innerHTML = `
                ${imgHtml}
                <div>
                    <span class="text-[9px] font-bold text-blue-500">[${res.region}] ${res.subCat}</span>
                    <h3 class="font-black text-gray-800 text-sm mt-0.5">${res.name}</h3>
                    <p class="text-xs text-gray-400 line-clamp-1 mt-0.5">${res.description}</p>
                    <p class="text-xs font-black yeogi-text-orange mt-1">${res.price > 0 ? res.price.toLocaleString()+'원' : '예약 비용 없음'}</p>
                </div>
            `;
            card.appendChild(infoDiv);

            // 수정/삭제 어드민 버튼 슬롯
            const btnGroup = document.createElement('div');
            btnGroup.className = "flex flex-col gap-1 pl-2 border-l";
            btnGroup.innerHTML = `
                <button onclick="showEditItemModal(${res.id})" class="text-[10px] px-2 py-1 border border-blue-200 rounded-md bg-white text-blue-500 font-bold hover:bg-blue-50">수정</button>
                <button onclick="deleteTravelItem(${res.id})" class="text-[10px] px-2 py-1 border border-red-200 rounded-md bg-white text-red-500 font-bold hover:bg-red-50">삭제</button>
            `;
            card.appendChild(btnGroup);
            container.appendChild(card);
        });
    }

    // 📍 1) 상위 카테고리 (지역) 직접 추가 제어 코어
    function addNewRegionDirect() {
        const name = prompt("새로 편입할 도시/지역명을 명명하십시오:");
        if(name && name.trim() !== "") {
            if(!db.regions.includes(name.trim())) {
                db.regions.push(name.trim()); saveDB();
                renderGlobalRegionSelect(); renderScrollRegionButtons();
            } else { alert("이미 존재하는 대상 지역 식별자입니다."); }
        }
    }

    function showEditRegionModal() {
        let opts = db.regions.map((r, i) => `<option value="${i}">${r}</option>`).join('');
        openGlobalModal("지정 상위 지역명 변경 수선", `
            <select id="edit-region-idx" class="w-full border p-2 rounded-lg text-sm bg-white">${opts}</select>
            <input id="edit-region-new-name" type="text" placeholder="새로운 지역 명칭 입력" class="w-full border p-2 rounded-lg text-sm">
        `, () => {
            const idx = parseInt(document.getElementById('edit-region-idx').value);
            const newN = document.getElementById('edit-region-new-name').value.trim();
            if(!newN) return alert("공백은 허용되지 않습니다.");
            
            const oldN = db.regions[idx];
            db.travelItems.forEach(item => { if(item.region === oldN) item.region = newN; });
            db.regions[idx] = newN; selectedRegionFilter = "all"; saveDB();
            renderGlobalRegionSelect(); renderScrollRegionButtons(); renderFilteredItemsGrid(); closeGlobalModal();
        });
    }

    function showDeleteRegionModal() {
        let opts = db.regions.map((r, i) => `<option value="${i}">${r}</option>`).join('');
        openGlobalModal("상위 지역 삭제 제어", `
            <p class="text-xs text-red-500 font-bold">* 경고: 삭제 시 해당 소속 아이템들은 '미분류' 처리됩니다.</p>
            <select id="del-region-idx" class="w-full border p-2 rounded-lg text-sm bg-white">${opts}</select>
        `, () => {
            const idx = parseInt(document.getElementById('del-region-idx').value);
            const targetN = db.regions[idx];
            if(confirm(`[${targetN}] 지역을 파기하시겠습니까?`)) {
                db.travelItems.forEach(item => { if(item.region === targetN) item.region = "미분류"; });
                db.regions.splice(idx, 1); selectedRegionFilter = "all"; saveDB();
                renderGlobalRegionSelect(); renderScrollRegionButtons(); renderFilteredItemsGrid();
            }
            closeGlobalModal();
        });
    }

    // 📁 2) 하위 카테고리 (분류/테마) CRUD 매니지먼트
    function addNewSubCategoryDirect() {
        const name = prompt(`현재 [${currentMainCategory}] 하위에 신규 지정할 테마/소분류명을 입력하세요:`);
        if(name && name.trim() !== "") {
            if(!db.subCategories[currentMainCategory]) db.subCategories[currentMainCategory] = [];
            if(!db.subCategories[currentMainCategory].includes(name.trim())) {
                db.subCategories[currentMainCategory].push(name.trim()); saveDB();
                renderScrollSubCategoryButtons();
            } else { alert("동일 카테고리 내에 존재하는 분류명입니다."); }
        }
    }

    function showEditSubCategoryModal() {
        const arr = db.subCategories[currentMainCategory] || [];
        let opts = arr.map((c, i) => `<option value="${i}">${c}</option>`).join('');
        openGlobalModal("하위 서브 카테고리 명칭 수선", `
            <select id="edit-sub-idx" class="w-full border p-2 rounded-lg text-sm bg-white">${opts}</select>
            <input id="edit-sub-new-name" type="text" placeholder="변경할 분류명칭 명명" class="w-full border p-2 rounded-lg text-sm">
        `, () => {
            const idx = parseInt(document.getElementById('edit-sub-idx').value);
            const newN = document.getElementById('edit-sub-new-name').value.trim();
            if(!newN) return;
            const oldN = arr[idx];
            db.travelItems.forEach(item => { if(item.mainCat === currentMainCategory && item.subCat === oldN) item.subCat = newN; });
            arr[idx] = newN; selectedSubCategoryFilter = "all"; saveDB();
            renderScrollSubCategoryButtons(); renderFilteredItemsGrid(); closeGlobalModal();
        });
    }

    function showDeleteSubCategoryModal() {
        const arr = db.subCategories[currentMainCategory] || [];
        let opts = arr.map((c, i) => `<option value="${i}">${c}</option>`).join('');
        openGlobalModal("하위 테마 카테고리 삭제 파기", `
            <select id="del-sub-idx" class="w-full border p-2 rounded-lg text-sm bg-white">${opts}</select>
        `, () => {
            const idx = parseInt(document.getElementById('del-sub-idx').value);
            const targetN = arr[idx];
            if(confirm(`[${targetN}] 하위 분류를 파기 소멸하시겠습니까?`)) {
                db.travelItems.forEach(item => { if(item.mainCat === currentMainCategory && item.subCat === targetN) item.subCat = "미분류"; });
                arr.splice(idx, 1); selectedSubCategoryFilter = "all"; saveDB();
                renderScrollSubCategoryButtons(); renderFilteredItemsGrid();
            }
            closeGlobalModal();
        });
    }

    // 🌉 3) 가짜 여행 상품 자체 추가 (사진 파일 업로드 드래그 앤 드롭 내장)
    function showAddItemModal() {
        let rOpts = db.regions.map(r => `<option value="${r}">${r}</option>`).join('');
        let scOpts = (db.subCategories[currentMainCategory] || []).map(sc => `<option value="${sc}">${sc}</option>`).join('');

        openGlobalModal(`새로운 ${currentMainCategory} 엔티티 추가 등록`, `
            <span class="text-[10px] text-orange-500 font-bold block">* 로컬 컴퓨터의 사진/이미지 파일을 아래 인풋으로 드래그 드롭하면 Base64 자동 업로드 호환됩니다.</span>
            <input id="add-item-name" type="text" placeholder="관광지 명칭 / 숙소 이름 / 항공편" class="w-full border p-2 rounded-lg text-sm">
            <select id="add-item-region" class="w-full border p-2 rounded-lg text-sm bg-white">${rOpts}</select>
            <select id="add-item-subcat" class="w-full border p-2 rounded-lg text-sm bg-white">${scOpts}</select>
            <input id="add-item-price" type="number" placeholder="예약 가상 금액 (숫자만)" class="w-full border p-2 rounded-lg text-sm">
            <textarea id="add-item-desc" placeholder="세부 요약 가짜 설명 정보 기술" class="w-full border p-2 rounded-lg text-sm h-20"></textarea>
            <input id="add-item-img" type="text" placeholder="사진 이미지 웹 링크 URL 또는 이미지 파일 드래그 드롭" 
                class="w-full border p-2 rounded-lg text-sm bg-gray-50 focus:bg-white"
                ondrop="handleImageDrop(event, 'add-item-img')" ondragover="onDragOver(event)" ondragleave="onDragLeave(event)">
        `, () => {
            const name = document.getElementById('add-item-name').value.trim();
            const region = document.getElementById('add-item-region').value;
            const subCat = document.getElementById('add-item-subcat').value;
            const price = parseInt(document.getElementById('add-item-price').value) || 0;
            const description = document.getElementById('add-item-desc').value;
            const img = document.getElementById('add-item-img').value;

            if(!name) return alert("식별 명칭은 필수항목입니다.");

            db.travelItems.push({
                id: Date.now(), mainCat: currentMainCategory, region, subCat, name, price, description, img, score: (4.0 + Math.random().toFixed(1))
            });
            saveDB(); renderFilteredItemsGrid(); renderRecommendList(); closeGlobalModal();
        });
    }

    // 여행 데이터 정보 수선 편집 수정 모달
    function showEditItemModal(id) {
        const item = db.travelItems.find(t => t.id === id);
        let rOpts = db.regions.map(r => `<option value="${r}" ${item.region === r ? 'selected':''}>${r}</option>`).join('');
        let scOpts = (db.subCategories[item.mainCat] || []).map(sc => `<option value="${sc}" ${item.subCat === sc ? 'selected':''}>${sc}</option>`).join('');

        openGlobalModal("기록 데이터 정보 수선", `
            <span class="text-[10px] text-blue-500 font-bold block">* 사진 이미지 파일 드래그 드롭 덮어쓰기 지원</span>
            <input id="edit-item-name" type="text" value="${item.name}" class="w-full border p-2 rounded-lg text-sm">
            <select id="edit-item-region" class="w-full border p-2 rounded-lg text-sm bg-white">${rOpts}</select>
            <select id="edit-item-subcat" class="w-full border p-2 rounded-lg text-sm bg-white">${scOpts}</select>
            <input id="edit-item-price" type="number" value="${item.price}" class="w-full border p-2 rounded-lg text-sm">
            <textarea id="edit-item-desc" class="w-full border p-2 rounded-lg text-sm h-20">${item.description}</textarea>
            <input id="edit-item-img" type="text" value="${item.img || ''}" class="w-full border p-2 rounded-lg text-sm bg-gray-50"
                ondrop="handleImageDrop(event, 'edit-item-img')" ondragover="onDragOver(event)" ondragleave="onDragLeave(event)">
        `, () => {
            item.name = document.getElementById('edit-item-name').value.trim();
            item.region = document.getElementById('edit-item-region').value;
            item.subCat = document.getElementById('edit-item-subcat').value;
            item.price = parseInt(document.getElementById('edit-item-price').value) || 0;
            item.description = document.getElementById('edit-item-desc').value;
            item.img = document.getElementById('edit-item-img').value;

            saveDB(); renderFilteredItemsGrid(); renderRecommendList(); closeGlobalModal();
        });
    }

    function deleteTravelItem(id) {
        if(confirm("해당 가짜 관광 요소를 영구 데이터베이스에서 말소 파기하시겠습니까?")) {
            db.travelItems = db.travelItems.filter(t => t.id !== id);
            saveDB(); renderFilteredItemsGrid(); renderRecommendList();
        }
    }

    // 🔍 4) 가짜 상세 정보 뷰포트 바인딩 및 렌더링
    function showItemDetailView(id) {
        currentActiveItemId = id;
        const item = db.travelItems.find(t => t.id === id);
        showSection('item-detail-section');

        const infoBox = document.getElementById('item-info-view');
        const imgUrl = item.img || 'https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=500&auto=format&fit=crop';
        
        infoBox.innerHTML = `
            <img src="${imgUrl}" class="w-full h-56 object-cover rounded-xl shadow-md mb-4 bg-gray-100">
            <span class="text-xs font-black px-2.5 py-1 rounded-md bg-slate-900 text-white">${item.region} · ${item.subCat}</span>
            <h2 class="text-2xl font-black text-gray-800 mt-2">${item.name}</h2>
            <div class="flex items-center gap-2 mt-1 mb-3 text-xs text-gray-500 font-bold">
                <span class="text-yellow-500">⭐ 평점 ${item.score}</span> | <span>리뷰 2,841개 반응</span>
            </div>
            <p class="text-xs text-gray-600 leading-relaxed bg-gray-50 p-3 rounded-lg border">${item.description || '상세 사양 메타데이터 정보가 기술되지 않은 여정 항목입니다.'}</p>
        `;

        document.getElementById('detail-price-text').innerText = item.price > 0 ? `${item.price.toLocaleString()}원` : '비용 없음';

        // 항공권 카테고리 전용 가짜 노선 스케줄 생성기 작동 제어
        const simBox = document.getElementById('flight-simulator-box');
        if(item.mainCat === "항공권") {
            simBox.classList.remove('hidden'); generateFakeFlightTickets(item);
        } else { simBox.classList.add('hidden'); }
    }

    function generateFakeFlightTickets(item) {
        const list = document.getElementById('flight-ticket-list');
        list.innerHTML = "";
        const codes = ["KE721", "OZ102", "7C1105", "TW211"];
        codes.forEach((code, i) => {
            const row = document.createElement('div');
            row.className = "flex justify-between items-center p-3 border rounded-lg text-xs bg-slate-50";
            row.innerHTML = `
                <div>
                    <span class="font-black text-gray-700">${code}</span>
                    <span class="text-gray-400 font-bold ml-2">08:${i}0 -> 10:20</span>
                </div>
                <span class="font-black text-orange-600">${(item.price + (i * 12000)).toLocaleString()}원</span>
            `;
            list.appendChild(row);
        });
    }

    // 🧳 5) 보관함 아키텍처 제어
    function addItemToStorage() {
        const item = db.travelItems.find(t => t.id === currentActiveItemId);
        db.storage.push({
            id: Date.now(), originId: item.id, name: item.name, price: item.price, region: item.region
        });
        saveDB(); updateStorageBadgeCount();
        alert(`[${item.name}] 항목을 가상 보관 플래너에 저장 완료했습니다.`);
    }

    function updateStorageBadgeCount() {
        document.getElementById('storage-count').innerText = db.storage.length;
    }

    function renderStorageItems() {
        const container = document.getElementById('storage-items-list');
        const totalText = document.getElementById('storage-total-price');
        container.innerHTML = "";
        let sum = 0;

        if(db.storage.length === 0) {
            container.innerHTML = "<p class='text-center py-10 text-gray-400 text-xs font-bold'>보관 플래너가 비어있습니다. 가짜 일정을 수집해 보세요!</p>";
            totalText.innerText = "0원"; return;
        }

        db.storage.forEach((item, index) => {
            sum += item.price;
            const div = document.createElement('div');
            div.className = "flex justify-between items-center py-3 border-b last:border-0 text-xs";
            div.innerHTML = `
                <div>
                    <span class="text-[9px] text-gray-400 font-bold">[${item.region}]</span>
                    <p class="font-bold text-gray-800">${item.name}</p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="font-black text-slate-700">${item.price > 0 ? item.price.toLocaleString()+'원' : '무료'}</span>
                    <button onclick="removeStorageItem(${index})" class="text-red-500 font-bold text-sm hover:scale-110">×</button>
                </div>
            `;
            container.appendChild(div);
        });
        totalText.innerText = sum.toLocaleString() + "원";
    }

    function removeStorageItem(index) {
        db.storage.splice(index, 1); saveDB(); updateStorageBadgeCount(); renderStorageItems();
    }

    // ⚡ 6) 가짜 실시간 예약 시뮬레이션 엔진 (핵심 요구사항 반영)
    function triggerFakeBookingSimulation() {
        showSection('booking-status-section');
        
        const bar = document.getElementById('booking-progress-bar');
        const text = document.getElementById('status-headline');
        const failNotice = document.getElementById('simulation-fail-notice');
        
        bar.style.width = "0%";
        text.innerText = "통신 인터페이스 암호화 세션 구성 중...";
        failNotice.classList.add('hidden');

        setTimeout(() => { bar.style.width = "35%"; text.innerText = "가상 예약 슬롯 정합성 대조 점검 중..."; }, 600);
        setTimeout(() => { bar.style.width = "70%"; text.innerText = "데이터 영속성 미러링 원격 인젝션 시도 중..."; }, 1400);
        setTimeout(() => { 
            bar.style.width = "100%"; 
            text.innerText = "⚠️ 가상 동기화 실패 (실제 예약 불가)";
            failNotice.classList.remove('hidden');
            
            // 시뮬레이션 안전 리셋 프로시저
            db.storage = []; saveDB(); updateStorageBadgeCount();
        }, 2200);
    }

    // 드래그 앤 드롭 서브 엔진 유틸리티 내부 추상화
    function handleImageDrop(e, inputId) {
        e.preventDefault(); e.currentTarget.classList.remove('drag-over');
        const file = e.dataTransfer.files[0];
        if (file && file.type.startsWith('image/')) {
            const reader = new FileReader();
            reader.onload = (event) => { document.getElementById(inputId).value = event.target.result; };
            reader.readAsDataURL(file);
        }
    }
    function onDragOver(e) { e.preventDefault(); e.currentTarget.classList.add('drag-over'); }
    function onDragLeave(e) { e.currentTarget.classList.remove('drag-over'); }

    // 공용 추상화 모달 제어 전역 프로토콜
    function openGlobalModal(title, content, onConfirm) {
        document.getElementById('modal-headline').innerText = title;
        document.getElementById('modal-body-content').innerHTML = content;
        document.getElementById('modal-action-confirm-btn').onclick = onConfirm;
        document.getElementById('global-modal').classList.remove('hidden');
    }
    function closeGlobalModal() { document.getElementById('global-modal').classList.add('hidden'); }
    function saveDB() { localStorage.setItem('yeogi_siro_db_v1', JSON.stringify(db)); }

    // 앱 인스턴스 초기 구동 기동
    initApp();
</script>

</body>
